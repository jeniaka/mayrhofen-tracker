# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Create database "mayrhofen_tracker" in your Cluster0
# Network Access → Add 0.0.0.0/0 (required for Render dynamic IPs)
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.k1ogcwd.mongodb.net/mayrhofen_tracker

# ── Google OAuth ──────────────────────────────────────────────────────────────
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client
# Authorized redirect URIs — add BOTH:
#   http://localhost:8080/auth/callback        (for local dev)
#   https://mayrhofen-tracker.onrender.com/auth/callback
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx

# ── Session secret ────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=64_char_random_hex_here

# ── Brevo email (optional for Phase 1) ───────────────────────────────────────
# app.brevo.com → Settings → SMTP & API → API Keys tab
# Key starts with xkeysib-
BREVO_API_KEY=xkeysib-xxxx
SMTP_FROM=noreply@mayrhofen-tracker.com

# ── App domain ────────────────────────────────────────────────────────────────
APP_DOMAIN=mayrhofen-tracker.onrender.com

# ── Server port ───────────────────────────────────────────────────────────────
PORT=8080
